# Copy to .env and fill in the variables
# EXAMPLE_VAR=example

# Local mode: use kubeconfig instead of in-cluster
# LOCAL_MODE=true
# LOCAL_NAMESPACE=your-namespace
# LOCAL_KUBE_CONTEXT=your-kube-context

# Presets shown in /dashboard-local (optional)
# DEV_NAMESPACE=your-dev-namespace
# DEV_KUBE_CONTEXT=your-dev-context
# PROD_NAMESPACE=your-prod-namespace
# PROD_KUBE_CONTEXT=your-prod-context

# Dashboard
# Mark red if restartCount >= this number (regardless of podCount)
# DASHBOARD_RESTART_RED_THRESHOLD=3

# Humio (logs) - used for clickable link on service name in dashboard
# https://cloud.humio.com/<repo>/search?...&query=...kubernetes.labels.app="*<serviceName>*"
# HUMIO_BASE_URL=https://cloud.humio.com
# HUMIO_REPO=your-humio-repo
# HUMIO_NAMESPACE=your-namespace
# HUMIO_TZ=UTC
# HUMIO_START=1h
