# Copy to .env and fill in the variables
# EXAMPLE_VAR=example

# Local mode: use kubeconfig instead of in-cluster
# LOCAL_MODE=true
# LOCAL_NAMESPACE=your-namespace
# LOCAL_KUBE_CONTEXT=your-kube-context

# Presets shown in /dashboard-local (optional)
# DEV_NAMESPACE=your-dev-namespace
# DEV_KUBE_CONTEXT=your-dev-context
# PROD_NAMESPACE=your-prod-namespace
# PROD_KUBE_CONTEXT=your-prod-context

# Dashboard
# Mark red if restartCount >= this number (regardless of podCount)
# DASHBOARD_RESTART_RED_THRESHOLD=3

# Log viewer integration (optional)
# Supported providers: humio, grafana, datadog
# LOG_PROVIDER=humio

# Base URL for your log platform
# LOG_BASE_URL=https://cloud.humio.com

# Humio/LogScale: repository name
# LOG_REPO=your-repo

# Grafana: datasource name (default: Loki)
# LOG_DATASOURCE=Loki

# Timezone for log queries (default: UTC)
# LOG_TZ=UTC

# Default lookback window (default: 7d)
# LOG_START=7d

# Namespace filter for log queries
# LOG_NAMESPACE=
